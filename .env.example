# sapa-dashboard environment variables
# Copy to .env.local and fill in as needed.

# When "true", fetches return baked fixtures instead of hitting SAPA.
# Used by the deployed Vercel build; leave unset locally to hit the real API.
VITE_DEMO_MODE=

# SAPA backend base URL. Defaults to http://localhost:8002.
VITE_API_BASE=

# PostHog project API key (starts with phc_). Optional — tracking is silent
# no-op when unset. Create a project at https://us.posthog.com.
VITE_POSTHOG_KEY=

# PostHog host. Defaults to https://us.i.posthog.com. Override for EU
# region (https://eu.i.posthog.com) or self-hosted instances.
VITE_POSTHOG_HOST=

# -------- Server-side only (no VITE_ prefix) --------
# The following run in the Vercel serverless function at
# /api/posthog-query. They MUST NOT be prefixed with VITE_ or they'd
# ship in the browser bundle.

# PostHog personal API key (starts with phx_). Create at
# https://us.posthog.com → Personal Settings → Personal API Keys.
# Scope: Query read only, on your specific project.
POSTHOG_PERSONAL_API_KEY=

# Numeric project id. Find at Project Settings → General → Project ID.
POSTHOG_PROJECT_ID=

# PostHog API host for server-side queries. Defaults to
# https://us.posthog.com. Note: NO 'i.' prefix for the query API
# (unlike the browser capture endpoint).
POSTHOG_HOST=
